# PostgreSQL source database
POSTGRES_HOST=mariadb.emerald.dataplatformsolution.com
POSTGRES_PORT=5432
POSTGRES_DB=ps_db
POSTGRES_USER=ps_user
POSTGRES_PASSWORD=nGqEC3P009PSiKDe
SOURCE_TABLE=public.telecom_cdr

# ETL Intervel 
SCHEDULE_INTERVAL_MINUTES=5

# # --- Số lượng bản ghi tối đa mỗi lần chạy (để tránh file CSV quá lớn) ---
BATCH_SIZE=

# OUTBOX: nơi đặt file CSV để Auto Loader đọc
OUTBOX_DIR=data/outbox
# SUCCESS: Auto Loader sẽ chuyển file sang đây nếu load thành công
SUCCESS_DIR=data/success
# FAILURE: Auto Loader sẽ chuyển file sang đây nếu load thất bại
FAILURE_DIR=data/failure
# REJECTED: file CSV chứa các bản ghi không hợp lệ bị bỏ qua
REJECTED_DIR=data/rejected
# CHECKPOINT: lưu trạng thái checkpoint để tránh load trùng
CHECKPOINT_DIR=data/checkpoint

# # --- Thư mục log ---
LOG_DIR=logs

# # --- Tên file checkpoint (SQLite database) ---
CHECKPOINT_DB_NAME=checkpoint.db

# # --- Múi giờ đầu ra (chỉ dùng cho log, dữ liệu luôn lưu UTC) ---
LOG_TIMEZONE=Asia/Ho_Chi_Minh
